---
const links = [
    {
        name: "Landing",
        url: "https://abdullahamin231.github.io/portfolio/work/backtestking/landing",
    },
    {
        name: "Overview",
        url: "https://abdullahamin231.github.io/portfolio/work/backtestking/overview",
    },
    {
        name: "Pricing",
        url: "https://abdullahamin231.github.io/portfolio/work/backtestking/pricing",
    },
];
---

<div class="flex flex-wrap gap-3 mt-3">
    {
        links.map((link) => (
            <a
                href={link.url}
                target="_blank"
                rel="noopener"
                class="px-3 py-1 text-xs rounded-md border border-zinc-800 text-zinc-400 hover:text-zinc-200 hover:border-zinc-700 transition-colors"
            >
                {link.name}
            </a>
        ))
    }
</div>
